          "block_id": null,
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "EXT. MEG MARCH\u2019S HOUSE. DAY. 1868."
        },
        {
          "element_id": "el-00250",
          "kind": "Action",
          "fragment": "whole",
          "line_range": null,
          "block_id": null,
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "From inside a modest rural cottage, Meg emerges, wiping her hands and muttering "
        },
        {
          "element_id": "el-00251",
          "kind": "Character",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00081",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "MEG"
        },
        {
          "element_id": "el-00252",
          "kind": "Parenthetical",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00081",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "(ashamed)"
        },
        {
          "element_id": "el-00253",
          "kind": "Dialogue",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00081",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "Fifty dollars, what was I thinking?"
        },
        {
          "element_id": "el-00254",
          "kind": "Action",
          "fragment": "whole",
          "line_range": null,
          "block_id": null,
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "She sees her two 3-year-olds, a boy and a girl, DAISY and DEMI, playing in the y"
        },
        {
          "element_id": "el-00255",
          "kind": "Character",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00082",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "DAISY AND DEMI"
        },
        {
          "element_id": "el-00256",
          "kind": "Dialogue",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00082",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "Mommy -- mommy!"
        },
        {
          "element_id": "el-00257",
          "kind": "Action",
          "fragment": "whole",
          "line_range": null,
          "block_id": null,
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "They fall into her arms, she accepts them and then sends them off to play again."
        },
        {
          "element_id": "el-00258",
          "kind": "Scene Heading",
          "fragment": "whole",
          "line_range": null,
          "block_id": null,
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "EXT. / INT. MARCH HOUSE. 1868."
        },
        {
          "element_id": "el-00259",
          "kind": "Action",
          "fragment": "whole",
          "line_range": null,
          "block_id": null,
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "... the music grows louder as we see empty rooms of the childhood home -- the at"
        },
        {
          "element_id": "el-00260",
          "kind": "Character",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00083",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "MARMEE (O.S.)"
        },
        {
          "element_id": "el-00261",
          "kind": "Dialogue",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00083",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "Beth! Beth?"
        },
        {
          "element_id": "el-00262",
          "kind": "Action",
          "fragment": "whole",
          "line_range": null,
          "block_id": null,
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "She doesn\u2019t respond."
        },
        {
          "element_id": "el-00263",
          "kind": "Scene Heading",
          "fragment": "whole",
          "line_range": null,
          "block_id": null,
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "INT. NEW YORK THEATRE. EVENING. 1868."
        },
        {
          "element_id": "el-00264",
          "kind": "Action",
          "fragment": "whole",
          "line_range": null,
          "block_id": null,
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "Shakespeare\u2019s Twelfth Night unfolds on stage. Jo is in the back, the cheap stand"
        },
        {
          "element_id": "el-00265",
          "kind": "Character",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00084",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "OLIVIA"
        },
        {
          "element_id": "el-00266",
          "kind": "Dialogue",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00084",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "...That you do think you are not what you are."
        },
        {
          "element_id": "el-00267",
          "kind": "Character",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00085",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "VIOLA"
        },
        {
          "element_id": "el-00268",
          "kind": "Dialogue",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00085",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "Then think you right, I am not what I am!"
        },
        {
          "element_id": "el-00269",
          "kind": "Action",
          "fragment": "whole",
          "line_range": null,
          "block_id": null,
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "Friedrich watches the play from his own, proper, seat. At a certain point, he se"
        }
      ]
    },
    {
      "number": 14,
      "items": [
        {
          "element_id": "el-00270",
          "kind": "Scene Heading",
          "fragment": "whole",
          "line_range": null,
          "block_id": null,
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "INT. NEW YORK THEATRE LOBBY. NIGHT. 1868."
        },
        {
          "element_id": "el-00271",
          "kind": "Action",
          "fragment": "whole",
          "line_range": null,
          "block_id": null,
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "The audience flows out of the theatre into the lobby. Jo, still in her theatrica"
        },
        {
          "element_id": "el-00272",
          "kind": "Action",
          "fragment": "whole",
          "line_range": null,
          "block_id": null,
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "She then follows behind the band of friends, drawn to them in spite of herself."
        },
        {
          "element_id": "el-00273",
          "kind": "Scene Heading",
          "fragment": "whole",
          "line_range": null,
          "block_id": null,
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "INT. GERMAN BEER HALL. NIGHT. 1868."
        },
        {
          "element_id": "el-00274",
          "kind": "Action",
          "fragment": "whole",
          "line_range": null,
          "block_id": null,
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "It is a rowdy and raucous crowd, drinking and dancing. Jo walks through the crow"
        },
        {
          "element_id": "el-00275",
          "kind": "Character",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00086",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "JO"
        },
        {
          "element_id": "el-00276",
          "kind": "Dialogue",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00086",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "I\u2019m sorry, I only speak English..."
        },
        {
          "element_id": "el-00277",
          "kind": "Character",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00087",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "YOUNG MAN"
        },
        {
          "element_id": "el-00278",
          "kind": "Dialogue",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00087",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "Come dance!"
        },
        {
          "element_id": "el-00279",
          "kind": "Action",
          "fragment": "whole",
          "line_range": null,
          "block_id": null,
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "He pulls her into the dance, and she does her best to follow along. It\u2019s whirlin"
        },
        {
          "element_id": "el-00280",
          "kind": "Action",
          "fragment": "whole",
          "line_range": null,
          "block_id": null,
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "THE PAST. INT. CONCORD. MARCH HOUSE. JO & MEG\u2019S ROOM. 186"
        },
        {
          "element_id": "el-00281",
          "kind": "Action",
          "fragment": "whole",
          "line_range": null,
          "block_id": null,
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "...the sisters, all together again in the past, in the snow- globe of girlhood a"
        },
        {
          "element_id": "el-00282",
          "kind": "Character",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00088",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "MEG"
        },
        {
          "element_id": "el-00283",
          "kind": "Dialogue",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00088",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "I know just who I\u2019ll dance with!"
        },
        {
          "element_id": "el-00284",
          "kind": "Character",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00089",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "AMY"
        },
        {
          "element_id": "el-00285",
          "kind": "Dialogue",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00089",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "Who will you dance with, Jo?"
        },
        {
          "element_id": "el-00286",
          "kind": "Character",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00090",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "JO"
        },
        {
          "element_id": "el-00287",
          "kind": "Dialogue",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00090",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "You know I never dance."
        },
        {
          "element_id": "el-00288",
          "kind": "Character",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00091",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "BETH"
        },
        {
          "element_id": "el-00289",
          "kind": "Dialogue",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00091",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "I can\u2019t dance."
        },
        {
          "element_id": "el-00290",
          "kind": "Character",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00092",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "AMY"
        },
        {
          "element_id": "el-00291",
          "kind": "Dialogue",
          "fragment": "whole",
          "line_range": null,
          "block_id": "block-00092",
          "dual_dialogue_group": null,
          "dual_dialogue_side": null,
          "text_preview": "Why can\u2019t we all go to the party?! It\u2019s not fair!"
        }
      ]
    }
  ]
}
